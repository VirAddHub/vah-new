{
    "name": "vah",
    "version": "1.0.0",
    "private": true,
    "engines": {
        "node": "20.x"
    },
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "db:inspect": "tsx scripts/db/inspect-tables.ts",
        "start:backend": "npm --workspace apps/backend run start",
        "start:frontend": "npm --workspace apps/frontend run dev",
        "build": "npm run build --workspace packages/shared && npm run build --workspace apps/frontend && npm run build --workspace apps/backend",
        "build:backend": "npm run -w apps/backend build",
        "dev:backend": "node apps/backend/dist/server/index.js",
        "install:all": "npm install --workspaces",
        "test": "npm run test --workspaces --if-present",
        "typecheck": "npm -w apps/frontend run type-check && npm -w apps/backend run typecheck:backend",
        "lint": "npm -w apps/frontend run lint",
        "format": "prettier -w .",
        "format:check": "prettier -c ."
    },
    "devDependencies": {
        "minimatch": "3.1.2",
        "@types/pg": "^8.10.0",
        "tsx": "^4.7.0",
        "@types/connect-pg-simple": "^7.0.3",
        "@types/cors": "^2.8.19",
        "@types/express-session": "^1.18.2",
        "jest-util": "^30.2.0",
        "turbo": "^1.10.0"
    },
    "resolutions": {
        "@types/react": "18.3.3",
        "@types/react-dom": "18.3.0"
    },
    "overrides": {
        "minimatch": "3.1.2",
        "dompurify": "^3.3.2",
        "marked": "^16.4.0",
        "elliptic": "^6.6.1",
        "sha.js": "^2.4.12",
        "pbkdf2": "^3.1.2",
        "cipher-base": "^1.0.4",
        "browserify-sign": "^4.2.1",
        "@babel/traverse": "^7.23.2",
        "braces": "^3.0.3",
        "serialize-javascript": "^6.0.1",
        "prismjs": "^1.30.0",
        "webpack": "^5.93.0",
        "tar": "^7.5.10",
        "axios": "^1.13.5",
        "@tootallnate/once": "^3.0.1",
        "esbuild": "^0.25.0"
    },
    "dependencies": {
        "pg": "^8.11.0",
        "@microsoft/microsoft-graph-client": "^3.0.7",
        "dompurify": "^3.3.2",
        "drizzle-kit": "^0.31.5",
        "isomorphic-fetch": "^3.0.0",
        "marked": "^16.4.0"
    }
}